# Base URL the browser uses to call PresenceHub API (Laravel).
# Login/register call this origin from the browser; ensure Laravel allows CORS for your web app origin
# (e.g. http://localhost:3000, https://presencehub.local).
# Match your API: with Docker Compose for Presence-Hub-API, nginx is typically on port 80 — use http://localhost
# If you map another host port, set it here (e.g. http://localhost:8080).
NEXT_PUBLIC_API_URL=http://localhost

# Optional: server-only base URL for Server Actions (e.g. Docker internal hostname).
# If unset, login/register fall back to NEXT_PUBLIC_API_URL.
# Use the API origin only (no trailing /api); paths like /api/v1/... are appended in code.
# API_URL=http://api:80

# Docker image build (bakes this into the client bundle at build time):
#   docker build --build-arg NEXT_PUBLIC_API_URL=http://localhost -t presencehub-web .
# docker-compose passes the same value via build.args and environment.
